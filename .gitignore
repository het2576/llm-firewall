# LLM Security Firewall — .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
.env
!.env.example

# SQLite dev DB
*.db
*.db-shm
*.db-wal

# Alembic
alembic/versions/__pycache__/

# Node / Next.js
node_modules/
.next/
out/
.npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment
.env.local
.env.development.local
.env.test.local
.env.production.local

# OS
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE
.vscode/
.idea/
*.iml

# Docker
.docker/

# Logs
logs/
*.log

# ML model cache
.cache/
sentence_transformers/
